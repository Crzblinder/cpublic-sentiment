# ============================================================
#  TalentMatch Engine 环境变量配置模板
#  使用方法：复制本文件为 .env，根据实际情况取消对应注释
#  cp .env.example .env
# ============================================================


# ====================== 通用参数 ======================
# 以下参数在"路线 A"和"路线 B"中均需配置

# -- 数据库 --
# Docker 环境使用 MySQL；本地快速启动可改用 SQLite
DATABASE_URL=mysql+pymysql://talentmatch:talentmatch@mysql:3306/talentmatch?charset=utf8mb4
DATABASE_URL_SQLITE=sqlite:///./talentmatch.db

# -- 向量库 --
VECTOR_DB_PATH=./chroma_data
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# HuggingFace 镜像源（中国大陆网络建议开启，首次下载模型更快）
# 可选值：https://hf-mirror.com（默认镜像）或你自己的代理地址
# HF_ENDPOINT=https://hf-mirror.com

# -- 应用 --
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# -- 前端 --
VITE_API_BASE_URL=http://localhost:8000


# ===========================================================
#  大模型运行模式 —— 请二选一
#  核心开关：USE_LOCAL_LLM
#    false（默认）→ 路线 A：云端 API 模式
#    true         → 路线 B：本地 Ollama 模式（零成本免密）
# ===========================================================

# 默认使用云端 API；如需本地运行，取消下面这行的注释并设为 true
# USE_LOCAL_LLM=false


# ===================== 路线 A：云端 API 模式 =====================
# 适用场景：有 OpenAI / 第三方兼容 API Key，追求最高推理质量
# 操作步骤：
#   1. 确保 USE_LOCAL_LLM=false（或不设置）
#   2. 填入你的 API Key
#   3. 运行 docker compose up --build -d

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 提示：OPENAI_API_KEY 留空时，系统仍可通过内置规则引擎正常运行（确定性降级）。


# ===================== 路线 B：本地 Ollama 模式 =====================
# 适用场景：无 API Key、内网环境、希望零成本运行
# 操作步骤：
#   1. 取消 USE_LOCAL_LLM=true 的注释
#   2. 确认 Ollama 服务地址（Docker 内部默认 http://ollama:11434）
#   3. 运行 make docker-up-ollama（自动拉取中文模型）
#
# 推荐模型：qwen2.5:7b（中文能力强，7B 参数量适合消费级 GPU）
# 更多模型：https://ollama.com/library

# USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
